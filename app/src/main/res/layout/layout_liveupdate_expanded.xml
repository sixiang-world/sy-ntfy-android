<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Topic / Subscription name -->
    <TextView
        android:id="@+id/liveupdate_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#1A1A1A"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium" />

    <!-- Notification message title -->
    <TextView
        android:id="@+id/liveupdate_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#5A5A5A"
        android:textSize="13sp"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/liveupdate_progress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="10dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#4A90D9" />

    <!-- Progress text row: percentage + file size -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/liveupdate_progress_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#888888"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/liveupdate_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
