<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Topic / Subscription name + emoji tags -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/liveupdate_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/liveupdate_priority_star"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="⭐"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/liveupdate_tags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="#888888"
            android:textSize="14sp"
            android:maxLines="1" />

    </LinearLayout>

    <!-- Notification message title -->
    <TextView
        android:id="@+id/liveupdate_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#5A5A5A"
        android:textSize="13sp"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Progress bar (only shown for download progress notifications) -->
    <ProgressBar
        android:id="@+id/liveupdate_progress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="10dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#4A90D9"
        android:visibility="gone" />

    <!-- Progress text row: percentage + file size (only shown for download progress) -->
    <LinearLayout
        android:id="@+id/liveupdate_progress_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/liveupdate_progress_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#888888"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/liveupdate_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Actions row: dynamically populated with click button + ntfy action buttons -->
    <LinearLayout
        android:id="@+id/liveupdate_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="end" />

</LinearLayout>
